# Rust build artifacts
target
**/*.rs.bk

# Docker files (not needed inside the image)
Dockerfile
Dockerfile*
.dockerignore
docker-compose*
docker-compose.yml

# Version control & metadata
.git
.gitignore
.github

# Docs & license (baked into the image via COPY only if needed)
README.md
LICENSE

# Environment & local state
.env
.env.*
!.env.example
.cache

# Editors & OS
.vscode
.idea
.editorconfig
.DS_Store

# Project-internal directories (must not enter the build context)
.backup
.mimocode
.claude

# Logs
*.log
