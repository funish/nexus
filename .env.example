# Server port (default: 3000)
PORT=3000

# Local cache directory for filesystem storage (default: ./.cache)
# Used when S3 is not configured (development / single-node deployments)
CACHE_DIR=./.cache

# GitHub Token for WinGet manifest access
# Optional: set this to increase GitHub API rate limits when fetching
# package manifests / the winget-pkgs tree.
# Get your token from: https://github.com/settings/tokens
# Required scopes: public_repo (for accessing public repositories)
GITHUB_TOKEN=

# S3 Storage Configuration for distributed / persistent caching
# Optional: if any required field is missing, the service falls back to
# filesystem storage (CACHE_DIR). Configure all fields to enable S3 storage.
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
